# Auto-Apply v2 environment
# Copy to .env and fill in. .env is git-ignored.

# ── LLM provider ─────────────────────────────────────────────────────────────
# Choose one: anthropic | openai | deepseek
LLM_PROVIDER=anthropic

# Anthropic (Claude) — recommended; vision-capable, best form-filling accuracy
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# OpenAI — vision-capable (gpt-4o is best; gpt-4o-mini is cheaper)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# DeepSeek — cheapest option; text-only (no vision), DOM-based extraction
# deepseek-chat = V3 (fast/cheap)   deepseek-reasoner = R1 (slower, stronger)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── Paths ─────────────────────────────────────────────────────────────────────
USER_PROFILE_PATH=./user_profile.json
ARTIFACTS_DIR=./artifacts

# ── Agent ─────────────────────────────────────────────────────────────────────
AGENT_MAX_STEPS=60
HEADLESS=false

# ── Submit policy ─────────────────────────────────────────────────────────────
# Confidence >= SUBMIT_THRESHOLD → auto-submit. Set to 101 to never auto-submit.
SUBMIT_THRESHOLD=75
# First N real submissions gated at this higher threshold to build trust
TRUST_BUILD_THRESHOLD=90
TRUST_BUILD_COUNT=20
